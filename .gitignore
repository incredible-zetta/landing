# ============================================================
# Zetta CRM — landing (.gitignore)
# Astro 5 + Tailwind 4
# ============================================================

# ---------- dependencies ----------
node_modules/
.pnpm-store/
.pnp.*
.yarn/

# ---------- build output ----------
dist/
.astro/
.output/
.vercel/
.netlify/
.svelte-kit/
.next/

# ---------- astro cache + type gen ----------
.astro/

# ---------- environment ----------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example

# ---------- logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- editor / OS ----------
.DS_Store
Thumbs.db
.idea/
.vscode/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# ---------- test / coverage ----------
coverage/
.nyc_output/

# ---------- misc ----------
*.tsbuildinfo
.cache/
.tmp/
temp/

# ---------- design docs (local only) ----------
reff/
DESIGN.md
PRODUCT.md

# ---------- lock (use package-lock.json for npm) ----------
yarn.lock
pnpm-lock.yaml

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
