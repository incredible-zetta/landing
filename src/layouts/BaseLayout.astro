---
import '../styles/global.css';
import Motion from '../components/Motion.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zetta CRM — The self-hosted CRM for AI operators',
  description = 'Own your data. Run it your way. Zetta CRM is a privacy-first, self-hosted CRM built for teams that deploy and manage fleets of AI agents.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="theme-color" content="#0B0F1C" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-bg">
      <div class="starfield"></div>
      <slot />
    </div>
    <Motion />
  </body>
</html>
