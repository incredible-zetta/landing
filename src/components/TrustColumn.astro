---
import Icon from '../lib/Icon.astro';
import { TRUST } from '../lib/data';
---

<aside class="flex flex-col gap-3 text-left sm:gap-3.5 lg:pt-2" aria-label="Trust badges">
  {TRUST.map((t) => (
    <div class="flex items-start gap-3 rounded-[var(--radius-lg)] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-3.5 backdrop-blur-md">
      <span class="ic mt-0.5 inline-flex h-7 w-7 flex-shrink-0 items-center justify-center text-[color:var(--color-primary)]" style="--ic-size: 17px;">
        <Icon name={t.icon as any} size={17} />
      </span>
      <div class="min-w-0">
        <h3 class="m-0 mb-1.5 text-[12px] font-semibold leading-[1.3] text-[color:var(--color-text-primary)]">{t.title}</h3>
        <p class="m-0 text-[11px] leading-[1.4] text-[color:var(--color-text-muted)]">{t.desc}</p>
      </div>
    </div>
  ))}
</aside>
