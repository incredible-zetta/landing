<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (!reduceMotion.matches) {
    document.documentElement.classList.add('motion-ready');
    gsap.registerPlugin(ScrollTrigger);
    gsap.defaults({ ease: 'power4.out', duration: 0.72 });

    requestAnimationFrame(() => {
      gsap.timeline()
        .to('[data-hero-reveal]', {
          autoAlpha: 1,
          y: 0,
          scale: 1,
          stagger: 0.08,
          clearProps: 'visibility',
        }, 0)
        .fromTo('[data-hero-reveal]',
          { y: 22, scale: 0.985 },
          { y: 0, scale: 1, stagger: 0.08, duration: 0.82 },
          0
        );

      gsap.to('[data-mascot] img', {
        y: -14,
        x: 8,
        scrollTrigger: {
          trigger: '[data-mascot]',
          start: 'top 78%',
          end: 'bottom 20%',
          scrub: 0.7,
        },
      });

      ScrollTrigger.batch('[data-scroll-reveal], [data-reveal]', {
        start: 'top 86%',
        once: true,
        batchMax: 8,
        onEnter: (batch) => gsap.to(batch, {
          autoAlpha: 1,
          y: 0,
          stagger: 0.045,
          duration: 0.64,
          overwrite: 'auto',
          clearProps: 'visibility',
        }),
      });

      gsap.fromTo('[data-scroll-reveal], [data-reveal]', { y: 18 }, { y: 18, duration: 0.01 });
    });
  }
</script>
