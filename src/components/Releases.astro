---
import Icon from '../lib/Icon.astro';
import { getRepoMeta, WIKI_GUIDES, REPO_SLUG, REPO_URL, WIKI_URL, API_BASE } from '../lib/github';

const { latest, tags, stars } = await getRepoMeta();

const fmtDate = (iso: string | null) =>
  iso ? new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
---

<section id="releases" class="container-page py-14" data-repo-slug={REPO_SLUG} data-api={API_BASE} data-repo-url={REPO_URL}>
  <h2 class="m-0 mb-1.5 text-[28px] font-bold tracking-[-0.02em] text-[color:var(--color-text-primary)] sm:text-[32px]">
    Latest <span class="headline-accent">releases</span> &amp; guides
  </h2>
  <p class="mt-1.5 max-w-[60ch] text-[14px] leading-6 text-[color:var(--color-text-secondary)]">
    Pulled straight from <a href={REPO_URL} target="_blank" rel="noreferrer" class="text-[color:var(--color-secondary)] hover:text-[color:var(--color-primary)]">{REPO_SLUG}</a>. Tags refresh automatically on every visit.
  </p>

  <div class="mt-6 grid gap-4 lg:grid-cols-[1.1fr_.9fr] lg:items-stretch">
    <!-- Latest release card -->
    <a
      href={latest.url}
      target="_blank"
      rel="noreferrer"
      data-latest-link
      class="group flex flex-col justify-between rounded-[var(--radius-xl)] border border-[rgba(123,92,255,.35)] bg-[linear-gradient(135deg,rgba(123,92,255,.16),rgba(0,213,255,.08))] p-6 transition hover:border-[color:var(--color-primary)]"
    >
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[rgba(0,0,0,.2)] px-3 py-1 text-[11px] font-bold uppercase tracking-[.16em] text-[color:var(--color-secondary)]">
          <Icon name="rocket" size={14} /> Latest release
        </span>
        <div class="mt-3 flex items-center gap-3">
          <span data-latest-tag class="font-mono text-[28px] font-bold text-[color:var(--color-text-primary)]">{latest.tag}</span>
          <span data-latest-date class="text-[12px] text-[color:var(--color-text-muted)]">{fmtDate(latest.publishedAt)}</span>
        </div>
        <p class="mt-2 text-[14px] leading-6 text-[color:var(--color-text-secondary)]">
          Pull <code class="rounded bg-black/30 px-1.5 py-0.5 font-mono text-[12px] text-[color:var(--color-text-primary)]">ghcr.io/incredible-zetta/crm:<span data-latest-tag-inline>{latest.tag}</span></code> and point your agents at <code class="rounded bg-black/30 px-1.5 py-0.5 font-mono text-[12px] text-[color:var(--color-text-primary)]">/mcp</code>.
        </p>
      </div>
      <span class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[color:var(--color-primary)]">
        Read release notes <Icon name="arrow-up-right" size={15} />
      </span>
    </a>

    <!-- Tags + stars -->
    <div class="flex flex-col rounded-[var(--radius-xl)] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6">
      <div class="flex items-center justify-between">
        <h3 class="m-0 text-[15px] font-semibold text-[color:var(--color-text-primary)]">Recent tags</h3>
        <a href={`${REPO_URL}/stargazers`} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-[12px] text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text-primary)]">
          <Icon name="star" size={14} /> <span data-repo-stars>{stars}</span> stars
        </a>
      </div>
      <div data-tag-list class="mt-4 flex flex-wrap gap-2">
        {tags.map((t) => (
          <a
            href={t.url}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 rounded-[var(--radius-pill)] border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] px-3 py-1.5 font-mono text-[12px] text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-primary)] hover:text-[color:var(--color-text-primary)]"
          >
            <Icon name="tag" size={12} /> {t.name}
          </a>
        ))}
      </div>
      <a href={`${REPO_URL}/tags`} target="_blank" rel="noreferrer" class="mt-auto pt-4 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[color:var(--color-secondary)] hover:text-[color:var(--color-primary)]">
        All tags <Icon name="arrow-up-right" size={15} />
      </a>
    </div>
  </div>

  <!-- Wiki install guides -->
  <h3 id="docs" class="mt-10 mb-3 text-[15px] font-semibold text-[color:var(--color-text-primary)]">
    Install guides <span class="text-[color:var(--color-text-muted)]">— from the wiki</span>
  </h3>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
    {WIKI_GUIDES.map((g) => (
      <a
        href={g.href}
        target="_blank"
        rel="noreferrer"
        class="flex items-center gap-2.5 rounded-[var(--radius-lg)] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3.5 py-3 text-[13px] font-medium text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-primary)] hover:text-[color:var(--color-text-primary)]"
      >
        <span class="ic inline-flex h-5 w-5 flex-shrink-0 items-center justify-center text-[color:var(--color-primary)]" style="--ic-size: 16px;">
          <Icon name={g.icon as any} size={16} />
        </span>
        {g.label}
      </a>
    ))}
  </div>
  <a href={WIKI_URL} target="_blank" rel="noreferrer" class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[color:var(--color-secondary)] hover:text-[color:var(--color-primary)]">
    Open full wiki <Icon name="arrow-up-right" size={15} />
  </a>
</section>

<script>
  // Live refresh: keep tags/release/stars current between deploys.
  const root = document.getElementById('releases');
  if (root) {
    const api = root.dataset.api!;
    const repoUrl = root.dataset.repoUrl!;
    const text = (sel: string, value: string) => {
      root.querySelectorAll<HTMLElement>(sel).forEach((el) => (el.textContent = value));
    };

    const refresh = async () => {
      try {
        const [relRes, tagsRes, repoRes] = await Promise.all([
          fetch(`${api}/releases/latest`),
          fetch(`${api}/tags`),
          fetch(api),
        ]);

        if (relRes.ok) {
          const rel = await relRes.json();
          if (rel?.tag_name) {
            text('[data-latest-tag]', rel.tag_name);
            text('[data-latest-tag-inline]', rel.tag_name);
            const link = root.querySelector<HTMLAnchorElement>('[data-latest-link]');
            if (link && rel.html_url) link.href = rel.html_url;
            if (rel.published_at) {
              text('[data-latest-date]', new Date(rel.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }));
            }
          }
        }

        if (tagsRes.ok) {
          const tags = await tagsRes.json();
          const list = root.querySelector<HTMLElement>('[data-tag-list]');
          if (list && Array.isArray(tags) && tags.length) {
            list.innerHTML = tags.slice(0, 6).map((t: any) => {
              const href = `${repoUrl}/releases/tag/${t.name}`;
              return `<a href="${href}" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-[var(--radius-pill)] border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] px-3 py-1.5 font-mono text-[12px] text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-primary)] hover:text-[color:var(--color-text-primary)]"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>${t.name}</a>`;
            }).join('');
          }
        }

        if (repoRes.ok) {
          const repo = await repoRes.json();
          if (typeof repo?.stargazers_count === 'number') {
            text('[data-repo-stars]', String(repo.stargazers_count));
          }
        }
      } catch {
        /* keep build-time values on failure */
      }
    };

    refresh();
  }
</script>
