---
import Icon from '../lib/Icon.astro';
import { NAV } from '../lib/data';
---

<footer class="container-page flex flex-wrap items-center justify-between gap-4 border-t border-[color:var(--color-border)] py-7">
  <style>
    .social-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: var(--radius-md);
      transition: color var(--dur-base) var(--ease-soft), background var(--dur-base) var(--ease-soft);
    }
    .social-icon:hover {
      color: var(--color-text-primary);
      background: var(--color-surface);
    }
  </style>
  <a href="/" class="flex items-center gap-2.5">
    <img src="/zetta-mark.png" alt="Z" class="h-[26px] rounded-md" />
    <b class="text-[15px] text-[color:var(--color-text-primary)]">{NAV.brand}</b>
  </a>
  <span class="text-[12px] text-[color:var(--color-text-muted)]">
    Open-source MCP CRM backend for AI agents.
  </span>
  <div class="flex items-center gap-1 text-[color:var(--color-text-muted)]">
    <a href="https://github.com/incredible-zetta/crm" target="_blank" rel="noreferrer" aria-label="Zetta CRM on GitHub" class="social-icon">
      <Icon name="github" size={18} />
    </a>
    <a href="https://twitter.com/" target="_blank" rel="noreferrer" aria-label="Zetta CRM on X" class="social-icon">
      <Icon name="twitter" size={18} />
    </a>
    <a href="#rss" aria-label="Zetta CRM RSS feed" class="social-icon">
      <Icon name="rss" size={18} />
    </a>
  </div>
</footer>
