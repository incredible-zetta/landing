---
import Icon from '../lib/Icon.astro';
import { NAV } from '../lib/data';
---

<nav class="container-page relative z-50 flex flex-wrap items-center gap-x-6 gap-y-3 py-[18px]">
  <a href="/" class="flex items-center gap-2.5">
    <img src="/zetta-mark.png" alt="Zetta CRM mark" class="h-[30px] w-auto rounded-md" />
    <b class="text-[17px] font-bold text-[color:var(--color-text-primary)]">{NAV.brand}</b>
  </a>

  <ul class="nav-links order-3 hidden w-full flex-1 items-center justify-center gap-6 lg:order-2 lg:flex lg:w-auto">
    {NAV.links.map((l) => (
      <li>
        <a
          href={l.href}
          class="text-[14px] font-medium text-[color:var(--color-text-secondary)] transition-colors duration-150 hover:text-[color:var(--color-text-primary)]"
        >
          {l.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="order-2 ml-auto flex items-center justify-end gap-2 sm:gap-3 md:order-3 lg:ml-0">
    <a
      href={NAV.github.href}
      target="_blank"
      rel="noreferrer"
      class="nav-github hidden items-center gap-2 rounded-[var(--radius-md)] border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] px-3 py-2 text-[13px] font-semibold text-[color:var(--color-text-primary)] transition hover:border-[color:var(--color-border-strong)] lg:inline-flex"
    >
      <Icon name="github" size={15} />
      {NAV.github.label}
      <span class="border-l border-[color:var(--color-border)] pl-2 text-[color:var(--color-text-muted)]">
        {NAV.github.count}
      </span>
    </a>
    <a class="btn btn-primary" href={NAV.cta.href}>
      {NAV.cta.label}
    </a>
    <button
      type="button"
      class="mobile-menu-trigger lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-trigger
    >
      <Icon name="menu" size={22} />
    </button>
  </div>

  <!-- Mobile menu sheet (md:hidden) -->
  <div
    id="mobile-menu"
    class="mobile-sheet absolute left-4 right-4 top-[calc(100%+8px)] z-50 origin-top rounded-[var(--radius-xl)] border border-[color:var(--color-border)] bg-[rgba(11,15,28,.96)] px-4 pb-6 pt-3 shadow-[0_24px_70px_rgba(0,0,0,.55)] backdrop-blur-xl lg:hidden"
    hidden
    data-menu-sheet
  >
    <ul class="flex flex-col">
      {NAV.links.map((l) => (
        <li>
          <a
            href={l.href}
            class="flex items-center justify-between border-b border-[color:var(--color-border)] py-3.5 text-[15px] font-medium text-[color:var(--color-text-secondary)] transition-colors hover:text-[color:var(--color-text-primary)]"
          >
            {l.label}
            <Icon name="arrow-right" size={16} />
          </a>
        </li>
      ))}
      <li class="pt-4">
        <a
          href={NAV.github.href}
          target="_blank"
          rel="noreferrer"
          class="flex items-center justify-center gap-2 rounded-[var(--radius-md)] border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] py-3 text-[14px] font-semibold text-[color:var(--color-text-primary)]"
        >
          <Icon name="github" size={16} />
          {NAV.github.label} · {NAV.github.count}
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .mobile-menu-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface-elevated);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: border-color var(--dur-base) var(--ease-soft);
  }
  .mobile-menu-trigger:hover { border-color: var(--color-border-strong); }

  @media (max-width: 1023px) {
    .nav-links,
    .nav-github { display: none !important; }
    .mobile-menu-trigger { display: inline-flex !important; }
  }

  @media (min-width: 1024px) {
    .mobile-menu-trigger { display: none; }
  }

  .mobile-sheet {
    animation: sheet-in 220ms var(--ease-out);
  }
  @keyframes sheet-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const trigger = document.querySelector<HTMLButtonElement>('[data-menu-trigger]');
  const sheet = document.querySelector<HTMLElement>('[data-menu-sheet]');
  if (trigger && sheet) {
    const setOpen = (open: boolean) => {
      sheet.hidden = !open;
      trigger.setAttribute('aria-expanded', String(open));
      trigger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    trigger.addEventListener('click', () => setOpen(sheet.hidden));
    sheet.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !sheet.hidden) setOpen(false);
    });
    window.addEventListener('resize', () => {
      if (window.matchMedia('(min-width: 1024px)').matches) setOpen(false);
    });
  }
</script>
