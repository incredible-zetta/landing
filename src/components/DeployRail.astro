---
import Icon from '../lib/Icon.astro';
import { DEPLOY_RAIL } from '../lib/data';
import { getRepoMeta, REPO_URL, WIKI_URL } from '../lib/github';

const { latest } = await getRepoMeta();
---

<section id="deploy" class="container-page py-14">
  <h2 class="m-0 mb-1.5 text-[28px] font-bold tracking-[-0.02em] text-[color:var(--color-text-primary)] sm:text-[32px]">
    Deploy Anywhere. <span class="headline-accent">You're in Control.</span>
  </h2>

  <div class="mt-6 grid gap-4 rounded-[var(--radius-xl)] border border-[rgba(123,92,255,.35)] bg-[linear-gradient(135deg,rgba(123,92,255,.16),rgba(0,213,255,.08))] p-5 shadow-[0_24px_80px_rgba(0,0,0,.22)] lg:grid-cols-[1.1fr_.9fr] lg:items-center">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(0,213,255,.35)] bg-[rgba(0,213,255,.08)] px-3 py-1 text-[11px] font-bold uppercase tracking-[.16em] text-[color:var(--color-cyan)]">
        <Icon name="rocket" size={14} /> Stable release
      </span>
      <h3 class="mt-3 text-[20px] font-bold tracking-[-0.02em] text-[color:var(--color-text-primary)]">{latest.tag} ships as a multi-platform GHCR image.</h3>
      <p class="mt-2 max-w-[68ch] text-[14px] leading-6 text-[color:var(--color-text-secondary)]">
        Pull one container, connect MySQL 8, set <code class="rounded bg-black/25 px-1.5 py-0.5 font-mono text-[12px] text-[color:var(--color-text-primary)]">BASE_URL</code>, and expose <code class="rounded bg-black/25 px-1.5 py-0.5 font-mono text-[12px] text-[color:var(--color-text-primary)]">/mcp</code> to your agents behind API-key auth.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={WIKI_URL} class="btn btn-primary">Install wiki</a>
        <a href={latest.url} class="btn btn-secondary">Release notes</a>
      </div>
    </div>
    <pre class="overflow-x-auto rounded-[var(--radius-lg)] border border-[color:var(--color-border)] bg-[#070A14] p-4 text-[12px] leading-6 text-[color:var(--color-text-secondary)]"><code>docker pull ghcr.io/incredible-zetta/crm:{latest.tag}

MCP_URL=https://crm.example.com/mcp
Authorization: Bearer $MCP_API_KEY</code></pre>
  </div>

  <div class="mt-6 flex flex-wrap gap-3.5">
    {DEPLOY_RAIL.map((r) => (
      <div
        class="flex min-w-[150px] flex-1 items-center gap-3 rounded-[var(--radius-lg)] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-4 transition duration-200 hover:border-[rgba(123,92,255,.4)]"
        style="--tw-shadow: var(--shadow-glow-card);"
      >
        <span class="ic inline-flex h-8 w-8 flex-shrink-0 items-center justify-center text-[color:var(--color-primary)]" style="--ic-size: 20px;">
          <Icon name={r.icon as any} size={20} />
        </span>
        <div class="min-w-0">
          <b class="block text-[13px] leading-[1.3] text-[color:var(--color-text-primary)]">{r.title}</b>
          <span class="text-[12px] text-[color:var(--color-text-muted)]">{r.sub}</span>
        </div>
      </div>
    ))}
  </div>
</section>
