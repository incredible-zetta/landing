---
import Icon from '../lib/Icon.astro';
import { DEPLOY_RAIL } from '../lib/data';
---

<section id="deploy" class="container-page py-14">
  <h2 class="m-0 mb-1.5 text-[28px] font-bold tracking-[-0.02em] text-[color:var(--color-text-primary)] sm:text-[32px]">
    Deploy Anywhere. <span class="headline-accent">You're in Control.</span>
  </h2>

  <div class="mt-6 flex flex-wrap gap-3.5">
    {DEPLOY_RAIL.map((r) => (
      <div
        class="flex min-w-[150px] flex-1 items-center gap-3 rounded-[var(--radius-lg)] border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-4 transition duration-200 hover:border-[rgba(123,92,255,.4)]"
        style="--tw-shadow: var(--shadow-glow-card);"
      >
        <span class="ic inline-flex h-8 w-8 flex-shrink-0 items-center justify-center text-[color:var(--color-primary)]" style="--ic-size: 20px;">
          <Icon name={r.icon as any} size={20} />
        </span>
        <div class="min-w-0">
          <b class="block text-[13px] leading-[1.3] text-[color:var(--color-text-primary)]">{r.title}</b>
          <span class="text-[12px] text-[color:var(--color-text-muted)]">{r.sub}</span>
        </div>
      </div>
    ))}
  </div>
</section>
